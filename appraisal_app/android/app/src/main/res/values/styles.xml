<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Theme applied to the Android Window while the process is starting (light mode) -->
    <!-- Uses dark background to prevent white flash regardless of OS mode -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowFullscreen">true</item>
    </style>
    <!-- Theme applied to the Android Window as soon as the process has started.
         Determines the color of the Android Window while your Flutter UI initializes. -->
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@color/splash_background</item>
    </style>
</resources>
